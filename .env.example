# ---------------------------------------------------------------------------
# Domain Configuration
# ---------------------------------------------------------------------------
# The public FQDN that Traefik will route to this service.
# Ensure the DNS A/AAAA record points to this server's public IP.
WAG_DOMAIN=wag.tsrv.uk
